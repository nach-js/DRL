// ============================================================
//  vcma_sweep_v2.mx3
//  Testing magnetic texture response to varying Ku1 (VCMA) in
//  Nb/Ta/CoFeB heterostructures. Nb~20nm, Ta~1nm, CoFeB~1.5nm
//
//  VCMA range: Ku1 = 0.63e6 to 0.734e6 J/m³ (±2V gate voltage)
//  SRT at Keff = 0 → Ku1_SRT = 0.628e6 J/m³
// ============================================================

// ── GRID ─────────────────────────────────────────────────────
Nx := 64
Ny := 64
Nz := 1

SetGridsize(Nx, Ny, Nz)
SetCellsize(3e-9, 3e-9, 1.5e-9)
// No SetGeom — full volume needed for correct B_demag across stack


// ── MATERIAL PARAMETERS ──────────────────────────────────────
Msat  = 1.0e6
Aex   = 15e-12
alpha = 0.02
anisU = vector(0, 0, 1)
Dind  = 0.06e-3
// Ku1 set below in initialization and loop


// ── DATA LOGGING ─────────────────────────────────────────────
TableAdd(E_total)
TableAdd(E_exch)
TableAdd(E_demag)
TableAdd(E_anis)
TableAdd(MaxTorque)


// ── CONVERGENCE ──────────────────────────────────────────────
RelaxTorqueThreshold = 1e-5


// ── INITIALIZATION ───────────────────────────────────────────
// Start from RandomMag and relax at mid-range Ku1 to establish
// ferromagnetic maze domain order before the sweep begins.
// This single state is reloaded at every step so texture
// differences are purely due to Ku1, not different random seeds.
Print("=== Initializing maze domain state ===")
Ku1 = 0.68e6
m = RandomMag()
Relax()
Print("Init MaxTorque = ", MaxTorque.Get())
Print("Init <m>       = ", m.Average())
Save(m)
Print("Initial state saved.")


// ── KU1 SWEEP ────────────────────────────────────────────────
N_steps   := 20
Ku1_start := 0.63e6
Ku1_end   := 0.734e6
Ku1_step  := (Ku1_end - Ku1_start) / 19.0

for i := 0; i < N_steps; i++ {
    Ku1_now := Ku1_start + i*Ku1_step

    Print("================================================")
    Print("Step : ", i)
    Print("Ku1  : ", Ku1_now)
    Print("Keff : ", Ku1_now - 6.28e5)
    Print("================================================")

    // Reload same initial state — independent relaxation at each Ku1
    m.LoadFile("m.ovf")

    Ku1 = Ku1_now
    Relax()

    Print("Converged | MaxTorque = ", MaxTorque.Get())
    Print("<m>       = ", m.Average())

    TableSave()

    SaveAs(m,               sprintf("m_%04d",        i))
    SaveAs(m.Comp(2),       sprintf("mz_%04d",       i))
    SaveAs(B_demag.Comp(2), sprintf("Bdz_%04d",      i))
}

Print("================================================")
Print("Sweep complete.")
Print("================================================")